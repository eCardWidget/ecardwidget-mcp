    "campaign": {
      "endpoint": "POST /v2/api/campaign/save",
      "wrapper": "campaign",
      "description": "A campaign's settable surface for `POST /campaign/save` (sent as `campaign`). Creating a campaign yields a draft; eCards, recipients, scheduling and sending are separate calls. Fields marked read-only are returned but ignored on input.",
      "required": [
