{
  "name": "ecardwidget-mcp",
  "version": "0.1.0",
  "description": "Official Model Context Protocol (MCP) server for eCardWidget \u2014 let an AI agent run your account (campaigns, widgets, automations, directory, eCards) with a scoped API key.",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "ecardwidget",
    "ecards",
    "ai",
    "agent"
  ],
  "homepage": "https://github.com/eCardWidget/ecardwidget-mcp",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/eCardWidget/ecardwidget-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/eCardWidget/ecardwidget-mcp/issues"
  },
  "license": "MIT",
  "type": "module",
  "bin": {
    "ecardwidget-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "SECURITY.md",
    "server.json"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "inspector": "npx @modelcontextprotocol/inspector node dist/index.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
